        "titulo": "Bonjour ! Les salutations",
        "gramatica": "Pronomes pessoais: je, tu, il/elle",
        "vocabulario": [
          "bonjour",
          "bonsoir",
          "merci",
          "s'il vous plaît",
          "au revoir"
        ],
        "nivel": "A0"
      },
      "gramatica": {
        "titulo": "Pronomes Pessoais Básicos",
        "explicacao": "Os pronomes pessoais são usados para substituir nomes de pessoas. Em francês, começamos com je, tu e il/elle. Eles têm formas diferentes para usar em frases.",
        "tabela": [
          "Pronome | Forma | Exemplo",
          "je | eu | Je m'appelle",
          "tu | você | Tu es étudiant",
          "il | ele | Il est français",
          "elle | ela | Elle est étudiante"
        ],
        "exemplos": [
          "Bonjour, je m'appelle Pierre.",
          "Tu es étudiant, n'est-ce pas?",
          "Il est français, elle est française."
        ],
        "dica": "Para memorizar, associe cada pronome a uma pessoa: je para si mesmo, tu para alguém conhecido e il/elle para alguém específico."
      },
      "exercicios": [
        {
          "tipo": "lacuna",
          "enunciado": "Complete: ___ m'appelle Marie. (eu)",
          "resposta": "Je"
        },
        {
          "tipo": "multipla_escolha",
          "enunciado": "Qual é a tradução de \"merci\"?",
          "opcoes": [
            "A) por favor",
            "B) obrigado",
            "C) bom dia"
          ],
          "resposta": "B"
        },
        {
          "tipo": "lacuna",
          "enunciado": "Complete: Il ___ français. (ele)",
          "resposta": "est"
        },
        {
          "tipo": "verdadeiro_falso",
          "enunciado": "\"Bonjour\" significa \"boa noite\". Verdadeiro ou Falso?",
          "resposta": "Falso — \"Bonjour\" significa \"bom dia\""
        },
        {
          "tipo": "traducao",
          "enunciado": "Traduza para francês: \"Thank you, please.\"",
          "resposta": "Merci, s'il vous plaît."
        }
      ],
      "dialogo": {
        "titulo": "Saudações Simples",
        "falas": [
          "Bonjour: Bonjour",
          "Alex: Bonjour",
          "Bonjour: Merci",
          "Alex: S'il vous plaît",
          "Bonjour: Au revoir",
          "Alex: Au revoir"
        ],
        "traducao": "Olá\nOlá\nObrigado\nPor favor\nTchau\nTchau"
      },
